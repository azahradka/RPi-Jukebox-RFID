{
  "name": "webapp",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.16",
    "@mui/material": "^5.14.17",
    "@mui/styles": "^5.14.17",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^12.1.5",
    "@testing-library/user-event": "^14.5.1",
    "date-fns": "^2.30.0",
    "i18next": "^22.5.1",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-http-backend": "^2.4.1",
    "jszmq": "^0.1.2",
    "ramda": "^0.29.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-i18next": "^12.3.1",
    "react-router-dom": "^6.18.0",
    "react-scripts": "^5.0.1",
    "url": "^0.11.3",
    "uuid": "^9.0.1"
  },
  "scripts": {
    "start": "node scripts/generate-commands.js && react-scripts start",
    "build": "node scripts/generate-commands.js && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "generate-commands": "node scripts/generate-commands.js",
    "check-commands": "node scripts/generate-commands.js --check"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-restricted-syntax": [
        "error",
        {
          "selector": "VariableDeclarator[init.type='AwaitExpression'][init.argument.callee.name='request'] > ObjectPattern:has(Property[key.name='error'])",
          "message": "Phase 5a FU#1: ``request()`` throws on failure (Phase 1 made the contract explicit); the legacy ``const { result, error } = await request(...)`` shape is dead. Use ``const { result } = await request(...)`` + try/catch, or opt into the legacy shape explicitly with ``await request(name, kwargs, { swallow: true })``."
        }
      ]
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.12.1"
  }
}
